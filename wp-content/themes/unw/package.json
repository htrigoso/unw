  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "test:utm": "k6 run test-utm/load-test-k6.js",
    "dev": "npm run clear && webpack-dev-server --progress --mode development",
    "build": "npm run clear && cross-env webpack --progress --mode production",
    "build:map": "npm run clear && cross-env SOURCE_MAP=true webpack --progress --mode production",
    "lint": "npx standard --fix",
    "clear": "if exist build rmdir /s /q build && if exist dist rmdir /s /q dist && if exist public rmdir /s /q public",
    "rm:packs": "if exist node_modules rmdir /s /q node_modules"
  },
  "browserslist": [
    "supports es6-module",
    "defaults and not ie <= 11",
    "last 2 versions",
    "> 1%"
  ],
  "dependencies": {
    "aos": "2.3.4",
    "bezier-easing": "3.0.0",
    "core-js": "^3.25.0",
    "events": "^3.3.0",
    "gsap": "3.15.0",
    "include-media": "2.0.0",
    "lodash": "^4.18.1",
    "pristinejs": "^1.1.0",
    "psl": "^1.15.0",
    "scrollmagic": "2.0.9",
    "scrollmagic-plugin-gsap": "1.0.4",
    "smooth-scrollbar": "^8.7.4",
    "swiper": "11.2.10",
    "vanilla-lazyload": "19.1.3"
  },
  "devDependencies": {
    "@babel/cli": "^7.2.3",
    "@babel/core": "^7.3.4",
    "@babel/eslint-parser": "^7.14.7",
