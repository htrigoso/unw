    "@babel/register": "^7.0.0",
    "@babel/runtime": "^7.8.4",
    "assets-webpack-plugin": "^7.1.0",
    "auto-bind": "^4.0.0",
    "autoprefixer": "^10.5.0",
    "babel-loader": "^10.1.1",
    "chalk": "^4.1.2",
    "compass-importer": "^0.4.1",
    "compression-webpack-plugin": "^12.0.0",
    "copy-webpack-plugin": "^14.0.0",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.4",
    "css-minimizer-webpack-plugin": "^8.0.0",
    "cssnano": "^7.1.5",
